# Local-only daemon mode (remote mode intentionally unsupported)
ASSISTANT_MODE=local

# Runtime paths
RUNTIME_DIR=/var/lib/local-ai-assistant
AUDIO_CAPTURE_DEVICE=default
AUDIO_PLAYBACK_DEVICE=default

# STT (whisper.cpp)
WHISPER_BIN=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/usr/local/share/assistantd/models/ggml-base.en-q5_1.bin

# Local LLM adapter (llama-server on 127.0.0.1:8080, SmolLM2-1.7B-Instruct Q4_K_M)
LLM_API_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=SmolLM2-1.7B-Instruct-Q4_K_M
LLM_SYSTEM_PROMPT_PATH=/etc/local-ai-assistant/system_prompt.txt

# TTS (piper)
TTS_BIN=/usr/local/bin/piper
TTS_VOICE_PATH=/opt/models/piper-voice.onnx

# Speech end detection (WebRTC VAD target)
VAD_AGGRESSIVENESS=2
VAD_SILENCE_MS=700
