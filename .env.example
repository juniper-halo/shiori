# Main daemon config source for local development.
# Copy this to /etc/local-ai-assistant/assistantd.env on target systems.
# Local-only mode: remote mode is intentionally unsupported in this scaffold phase.
ASSISTANT_MODE=local
RUNTIME_DIR=/var/lib/local-ai-assistant
AUDIO_DEVICE=default
WHISPER_BIN=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/usr/local/share/assistantd/models/ggml-base.en-q5_1.bin
LLM_API_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=local-default-model
TTS_BIN=/usr/local/bin/piper
TTS_VOICE_PATH=/opt/models/piper-voice.onnx
VAD_AGGRESSIVENESS=2
VAD_SILENCE_MS=700
